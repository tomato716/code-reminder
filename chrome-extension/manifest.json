{
  "manifest_version": 3,
  "name": "Code Reminder (백준 복습 알리미)",
  "version": "1.0.0",
  "description": "코딩테스트 오답 복습을 도와주는 알림 서비스입니다.",
  "permissions": ["notifications", "storage"],
  "host_permissions": ["http://localhost:8080/*", "https://www.acmicpc.net/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.acmicpc.net/status*"],
      "js": ["content.js"]
    }
  ]
}
